    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^23.0.1",
    "postcss": "^8.5.15",
    "prettier": "^3.1.1",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
